{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Robot SSR Control",
  "version": "0.1.0",
  "identifier": "com.robot-ssr.control",
  "build": {
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Robot SSR Control",
        "width": 700,
        "height": 600,
        "resizable": true,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
